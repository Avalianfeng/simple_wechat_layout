# DeepSeek API（服务端使用，勿写到前端）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# 长文控制（可选）
# DEEPSEEK_TIMEOUT_MS=60000
# DEEPSEEK_MAX_TIMEOUT_MS=180000
# DEEPSEEK_MAX_CHARS=25000
# DEEPSEEK_CHUNK_CHARS=5500

# 网络（可选；慢网/偶发连不上时可调大）
# DEEPSEEK_CONNECT_TIMEOUT_MS=30000
# DEEPSEEK_RETRY_TIMES=1

# Token 参考单价（元 / 百万 tokens，仅展示用，不扣费）
# 默认按 DEEPSEEK_MODEL 选 V4 Flash / Pro 公开价；也可手动覆盖：
# DEEPSEEK_PRICE_INPUT_CACHE_HIT=0.02
# DEEPSEEK_PRICE_INPUT=1
# DEEPSEEK_PRICE_OUTPUT=2

# 账号
# 新用户默认每日 AI 次数（-1 表示不限）
DEFAULT_DAILY_AI_LIMIT=5
# 注册邀请码（设置后注册必须填写；防反复开号白嫖）
REGISTER_INVITE_CODE=change-me-invite
# 同一 IP 每天最多注册账号数（0=不限制 IP）
REGISTER_PER_IP_PER_DAY=2
# 每用户最多保存几篇历史（超出删最早，并清理未再引用的图片）
HISTORY_LIMIT=10
# 管理后台令牌（访问 /admin.html，请求头 X-Admin-Token）
ADMIN_TOKEN=change-me-to-a-long-secret
# 生产环境 Cookie 是否强制 Secure（默认 production 时开启）
# COOKIE_SECURE=1
# SQLite 路径（默认 data/app.db）
# SQLITE_PATH=

# 页脚联系（微信号会显示在首页，并可复制）
SUPPORT_WECHAT=cylf_19956272658
# SUPPORT_CONTACT=

# 服务
PORT=3080
# 对外访问根地址（上传图片 URL 用；本地可留空，自动用请求 host）
PUBLIC_BASE_URL=
